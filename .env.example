# ─────────────────────────────────────────────────────────────
#  DailyWish — Environment Configuration
#  Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Database (Supabase Postgres) ──────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string.
# Use the "Transaction pooler" URI (host *.pooler.supabase.com, port 6543) for
# the app at runtime — the driver sets prepare:false as the pooler requires:
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# For one-off migrations/seeds you may instead use the direct connection
# (port 5432) if your network allows it.
# Leave DATABASE_URL empty to run on the in-memory static catalog.

# Supabase client keys are NOT used (this app talks to Postgres directly via
# Drizzle and keeps its own JWT auth), but are harmless to keep:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Auth secrets (generate with: openssl rand -base64 48) ─────
JWT_SECRET=
JWT_REFRESH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Seed / bootstrap admin account ────────────────────────────
ADMIN_EMAIL=admin@dailywish.pk
ADMIN_PASSWORD=Admin@12345

# ── Image hosting (Cloudinary) — optional ─────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email ─────────────────────────────────────────────────────
# EMAIL_PROVIDER: console | resend | smtp
EMAIL_PROVIDER=console
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=DailyWish <no-reply@dailywish.pk>

# ── Payments (Stripe) ─────────────────────────────────────────
# Server-only. Use a TEST key (sk_test_…) in development.
STRIPE_SECRET_KEY=
# Optional least-privilege alternative to the secret key (rk_test_…/rk_live_…).
STRIPE_RESTRICTED_KEY=
# Webhook signing secret (whsec_…). Get it from the Stripe dashboard, or for
# local dev run:  stripe listen --forward-to localhost:3000/api/webhooks/stripe
# Card payments still settle WITHOUT this (the success page re-verifies the
# PaymentIntent via /api/checkout/confirm), but a verified webhook is the
# authoritative path and REQUIRED in production.
STRIPE_WEBHOOK_SECRET=
# Safe to expose to the browser (pk_test_…/pk_live_…). Required for the card form.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
